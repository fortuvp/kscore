# ======================================================
# DEX8004 - Example configuration (copy to .env)
# ======================================================

# --- Agent registry indexing (The Graph gateway) ---
THEGRAPH_API_KEY=<thegraph-api-key>
SEPOLIA_SUBGRAPH_KEY=6wQRC7geo9XYAhckfmfo8kbMRLeWU8KQd3XsJqFKmZLT
ETHEREUM_MAINNET_SUBGRAPH_KEY=FV6RR6y13rsnCxBAicKuQEwDp8ioEGiNaWaZUmvr1F8k
BASE_MAINNET_SUBGRAPH_KEY=43s9hQRurMGjuYnC1r2ZwS6xSQktbFyXMPMqGKUFJojb
BSC_MAINNET_SUBGRAPH_KEY=D6aWqowLkWqBgcqmpNKXuNikPkob24ADXCciiP8Hvn1K
POLYGON_MAINNET_SUBGRAPH_KEY=9q16PZv1JudvtnCAf44cBoxg82yK9SSsFvrjCY9xnneF

# --- Legacy Curate backend setting ---
# Verified Agents now uses the two PGTCR deployments below. This remains for
# backwards compatibility with older server integrations.
CURATE_MODE=pgtcr

# --- Verified Agents: Stake Curate / PGTCR deployments ---
# The unsuffixed PGTCR_* values remain supported as Sepolia aliases.
GTCR_REGISTRY_ADDRESS=0x8f6ac2ad41bee647fa3e37cadf8d359bd2584900
PGTCR_REGISTRY_ADDRESS=0x3162df9669affa8b6b6ff2147afa052249f00447
PGTCR_SEPOLIA_REGISTRY_ADDRESS=0x3162df9669affa8b6b6ff2147afa052249f00447
PGTCR_MAINNET_REGISTRY_ADDRESS=0x118155741eea23f56b3bd59b0c1342d5daaa6d07
NEXT_PUBLIC_PGTCR_SEPOLIA_REGISTRY_ADDRESS=0x3162df9669affa8b6b6ff2147afa052249f00447
NEXT_PUBLIC_PGTCR_MAINNET_REGISTRY_ADDRESS=0x118155741eea23f56b3bd59b0c1342d5daaa6d07

# --- Curate subgraphs ---
ENVIO_SUBGRAPH_URL=
PGTCR_GOLDSKY_SUBGRAPH_URL=
PGTCR_SEPOLIA_GOLDSKY_SUBGRAPH_URL=https://api.goldsky.com/api/public/project_cmgx9all3003atlp2bqha1zif/subgraphs/pgtcr-sepolia/v0.0.2/gn
PGTCR_MAINNET_GOLDSKY_SUBGRAPH_URL=https://api.goldsky.com/api/public/project_cmgx9all3003atlp2bqha1zif/subgraphs/pgtcr-mainnet/v0.0.1/gn
GOLDSKY_API_KEY=<goldsky-api-key>

# --- Public app/runtime settings ---
NEXT_PUBLIC_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SEPOLIA_RPC_URL=https://ethereum-sepolia.publicnode.com
NEXT_PUBLIC_ETHEREUM_RPC_URL=https://ethereum-rpc.publicnode.com
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=<walletconnect-project-id>

# --- Optional dedicated server-side RPCs for reputation fallback ---
# If omitted, the app falls back to viem's default public RPCs for the supported chains.
SEPOLIA_RPC_URL=
ETHEREUM_RPC_URL=
BASE_RPC_URL=
BSC_RPC_URL=
POLYGON_RPC_URL=

# --- Public contract addresses (Sepolia) ---
NEXT_PUBLIC_ESCROW_ADDRESS=0x338f1A474e0FB0ae9E913cFA3d7c6Aa19b92015B
NEXT_PUBLIC_REALITY_PROXY_ADDRESS=0x05B942fAEcfB3924970E3A28e0F230910CEDFF45
NEXT_PUBLIC_CURATE_REGISTRY_ADDRESS=0x8f6ac2ad41bee647fa3e37cadf8d359bd2584900
NEXT_PUBLIC_AGENT_REGISTRY_SEPOLIA_ADDRESS=0x8004A818BFB912233c491871b3d84c89A494BD9e

# --- Optional feature flags (0/1) ---
FEATURE_HEALTH_CHECKS=0
FEATURE_PLAYGROUND=0
FEATURE_WALLET_WRITES=0

# --- Reputation freshness fallback (0/1) ---
# When enabled, agent detail APIs can merge newer on-chain ReputationRegistry events
# on top of stale subgraph feedback for supported chains.
FEATURE_REPUTATION_RPC_FALLBACK=1

# Optional per-network overrides (inherit global flag when omitted)
FEATURE_REPUTATION_RPC_FALLBACK_SEPOLIA=
FEATURE_REPUTATION_RPC_FALLBACK_ETHEREUM=
FEATURE_REPUTATION_RPC_FALLBACK_BASE=
FEATURE_REPUTATION_RPC_FALLBACK_BSC=
FEATURE_REPUTATION_RPC_FALLBACK_POLYGON=
